{
  "name": "gutu-lib-admin-builders",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/admin-builders build",
    "typecheck": "bun run --cwd framework/libraries/admin-builders typecheck",
    "lint": "bun run --cwd framework/libraries/admin-builders lint",
    "test": "bun run --cwd framework/libraries/admin-builders test",
    "test:unit": "bun run --cwd framework/libraries/admin-builders test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
